generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  displayName          String?
  companyName          String?
  email                String    @unique
  onboardingCompleted  Boolean   @default(false)
  createdAt            DateTime  @default(now())
  contacts             Contact[]
  deals                Deal[]
  tasks                Task[]
  invoices             Invoice[]
  intakeSubmissions    IntakeSubmission[]
  assignedTasks        Task[]              @relation("AssignedTasks")
  assignedIntake       IntakeSubmission[]  @relation("AssignedIntake")
  assignedDeals        Deal[]              @relation("AssignedDeals")
}

model Contact {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  companyName String?
  notes       String?
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  deals       Deal[]
}

model Deal {
  id                String   @id @default(cuid())
  title             String
  value             Float?
  stage             String   @default("lead")
  expectedCloseDate DateTime?
  createdAt         DateTime @default(now())
  contactId         String
  contact           Contact   @relation(fields: [contactId], references: [id])
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  assignedToId      String?
  assignedUser      User?     @relation("AssignedDeals", fields: [assignedToId], references: [id])
  invoices          Invoice[]
}

model Task {
  id           String    @id @default(cuid())
  title        String
  description  String?
  status       String    @default("todo")
  dueDate      DateTime?
  createdAt    DateTime  @default(now())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  assignedToId String?
  assignedUser User?     @relation("AssignedTasks", fields: [assignedToId], references: [id])
}

model Invoice {
  id          String    @id @default(cuid())
  title       String
  amount      Float
  status      String    @default("draft")
  issuedDate  DateTime  @default(now())
  dueDate     DateTime?
  paidAt      DateTime?
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  dealId      String?
  deal        Deal?     @relation(fields: [dealId], references: [id])
}

model IntakeSubmission {
  id           String   @id @default(cuid())
  name         String
  email        String
  message      String
  type         String   @default("general")
  source       String   @default("external")
  status       String   @default("new")
  reference    String   @unique
  data         Json?
  decisionNote String?
  decidedAt    DateTime?
  assignedToId String?
  assignedUser User?    @relation("AssignedIntake", fields: [assignedToId], references: [id])
  createdAt    DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
}
